# ─── Ambassador Assistant — WINDOWS DEV ───────────────────
# Copy this file to .env and fill in real values.

# Supabase Postgres (find in Supabase Dashboard > Settings > Database > Connection string > URI)
DATABASE_URL=postgresql://postgres.XXXX:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Supabase project (optional, for future REST usage)
SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_CHAT_ID=123456789

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...
SCORING_MODEL=openai/gpt-4o
SCORING_MODE=llm

# X handle (without @)
MAIN_X_HANDLE=your_main_handle

# Metrics mode: 'manual' (ask via Telegram) or 'auto' (UI scrape attempt)
METRICS_MODE=manual

# Shared secret for PAD -> Backend ingest calls
INGEST_SHARED_SECRET=change-me-to-something-random

# Scoring
SCORING_DELAY_HOURS=48
WORKER_POLL_SECONDS=300

# Classification runtime mode
CLASSIFICATION_MODE=rules
AUTO_CREATE_PROJECTS=true

# Logging
LOG_LEVEL=DEBUG
LOG_DIR=logs

# Timezone
TIMEZONE=Asia/Jerusalem
