# ─── Ambassador Assistant — LINUX PRODUCTION ──────────────
# Copy this file to .env and fill in real values.
# On Linux: cp .env.prod.example .env

# Supabase Postgres
DATABASE_URL=postgresql://postgres.XXXX:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Supabase project
SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_CHAT_ID=123456789

# LLM provider
LLM_PROVIDER=minimax
SCORING_MODEL=MiniMax-M2.5
SCORING_MODE=llm
MINIMAX_API_KEY=your_minimax_key
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_CHAT_PATH=/text/chatcompletion_v2
OPENROUTER_API_KEY=

# X handle (without @)
MAIN_X_HANDLE=your_main_handle

# Metrics mode
METRICS_MODE=manual

# Shared secret — must match what PAD sends in X-Shared-Secret header
INGEST_SHARED_SECRET=change-me-to-something-random

# Scoring
SCORING_DELAY_HOURS=48
WORKER_POLL_SECONDS=300
WORKER_BATCH_SIZE=10
WORKER_CONCURRENCY=3

# Classification runtime mode
CLASSIFICATION_MODE=rules
AUTO_CREATE_PROJECTS=true

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Timezone
TIMEZONE=Asia/Jerusalem
